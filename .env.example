# Copy this file to .env and fill in REAL values. Do NOT commit .env.
# .env.example must contain ONLY placeholders (this file is checked into git).

# Azure OpenAI ────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT = "https://your-resource.openai.azure.com/"
AZURE_OPENAI_KEY = "your-azure-openai-key"
AZURE_OPENAI_API_VERSION = "2024-12-01-preview"

# Embedding model deployment (use text-embedding-3-large for best Arabic quality)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT = "text-embedding-3-large"

# Chat model deployment (GPT-4.1 for the AI lawyer answer generation)
AZURE_OPENAI_CHAT_DEPLOYMENT = "gpt-4.1"

# Neo4j ───────────────────────────────────────────────────────
NEO4J_URI = "neo4j://127.0.0.1:7687"
NEO4J_USER = "neo4j"
NEO4J_PASSWORD = "your-neo4j-password"
